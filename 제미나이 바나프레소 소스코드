제미나이 바나프레소 소스코드 (메인/왼쪽/오른쪽 전부) 


<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>바나프레소 - Banapresso</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;700;900&display=swap');
        
        body {
            font-family: 'Noto Sans KR', sans-serif;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* 메인 스플릿 레이아웃: 일반 웹사이트 비율 */
        .main-container {
            display: flex;
            height: 100vh;
            width: 100%;
        }

        .side-section {
            flex: 1;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        /* 업로드된 이미지 배경 설정 */
        .bg-img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            transition: transform 0.8s cubic-bezier(0.2, 1, 0.3, 1);
            z-index: 1;
        }

        /* 왼쪽 이미지 */
        .left-section .bg-img {
            background-image: url('바나프레소 이미지(왼쪽).jpg');
        }

        /* 오른쪽 이미지 */
        .right-section .bg-img {
            background-image: url('바나프레소 오른쪽 이미지.jpg');
        }

        .side-section:hover .bg-img {
            transform: scale(1.1);
        }

        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.25);
            z-index: 2;
            transition: background 0.4s ease;
        }

        .side-section:hover .overlay {
            background: rgba(0, 0, 0, 0.15);
        }

        /* 중앙 정사각형 버튼 */
        .square-btn {
            position: relative;
            z-index: 10;
            width: 200px;
            height: 200px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(5px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            transition: all 0.4s ease;
            text-decoration: none;
            color: #333;
            border-radius: 4px;
        }

        .side-section:hover .square-btn {
            background: #f82a93; /* 바나프레소 시그니처 핑크 */
            color: white;
            transform: translateY(-10px);
        }

        .square-btn span {
            font-size: 1.3rem;
            font-weight: 800;
            margin-top: 15px;
            letter-spacing: -0.5px;
        }

        /* 하부 페이지 섹션 */
        .sub-page {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: white;
            z-index: 100;
            transform: translateY(100%);
            transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);
            overflow-y: auto;
        }

        .sub-page.active {
            transform: translateY(0);
        }

        .close-trigger {
            position: fixed;
            top: 30px;
            right: 30px;
            z-index: 150;
            background: #222;
            color: white;
            padding: 12px 20px;
            border-radius: 30px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        /* 메뉴 카드 스타일 */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 30px;
            padding: 50px 0;
        }

        .menu-item {
            background: #fdfdfd;
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            border: 1px solid #f0f0f0;
            transition: all 0.3s ease;
        }

        .menu-item:hover {
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            border-color: #f82a93;
        }

        .pink-point { color: #f82a93; }
        .pink-bg { background-color: #f82a93; }
    </style>
</head>
<body>

    <div class="main-container">
        <!-- 왼쪽: 주문하기 섹션 -->
        <div class="side-section left-section" onclick="showSubPage('order-view')">
            <div class="bg-img"></div>
            <div class="overlay"></div>
            <div class="square-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span>주문하기</span>
            </div>
        </div>

        <!-- 오른쪽: 가맹점 신청 섹션 -->
        <div class="side-section right-section" onclick="showSubPage('franchise-view')">
            <div class="bg-img"></div>
            <div class="overlay"></div>
            <div class="square-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span>가맹점 신청하기</span>
            </div>
        </div>
    </div>

    <!-- 닫기 버튼 -->
    <div id="btn-close" class="close-trigger hidden" onclick="hideAllSubPages()">닫기 &times;</div>

    <!-- 메뉴 리스트 페이지 -->
    <div id="order-view" class="sub-page">
        <div class="max-w-6xl mx-auto px-6 py-20">
            <header class="text-center mb-16">
                <h2 class="text-5xl font-black mb-4">BANAPRESSO <span class="pink-point">MENU</span></h2>
                <div class="w-20 h-1 pink-bg mx-auto mb-6"></div>
                <p class="text-gray-500 text-lg">가장 맛있는 순간, 바나프레소 메뉴 리스트</p>
            </header>
            
            <div class="menu-grid" id="menu-list">
                <!-- 메뉴 아이템 동적 생성 -->
            </div>
        </div>
    </div>

    <!-- 가맹 신청 페이지 -->
    <div id="franchise-view" class="sub-page">
        <div class="max-w-3xl mx-auto px-6 py-20">
            <header class="text-center mb-16">
                <h2 class="text-5xl font-black mb-4">가맹점 <span class="pink-point">신청</span></h2>
                <div class="w-20 h-1 pink-bg mx-auto mb-6"></div>
                <p class="text-gray-500 text-lg">바나프레소와 함께할 성공 파트너를 기다립니다</p>
            </header>

            <form class="bg-white border border-gray-100 shadow-2xl rounded-3xl p-10 space-y-8" onsubmit="event.preventDefault(); alert('신청이 접수되었습니다.'); hideAllSubPages();">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="font-bold text-gray-700">이름</label>
                        <input type="text" placeholder="성함 입력" class="w-full bg-gray-50 border-none p-4 rounded-xl focus:ring-2 focus:ring-[#f82a93] outline-none">
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-gray-700">연락처</label>
                        <input type="tel" placeholder="010-0000-0000" class="w-full bg-gray-50 border-none p-4 rounded-xl focus:ring-2 focus:ring-[#f82a93] outline-none">
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="font-bold text-gray-700">희망 개설 지역</label>
                    <input type="text" placeholder="시/군/구 구체적 지역명" class="w-full bg-gray-50 border-none p-4 rounded-xl focus:ring-2 focus:ring-[#f82a93] outline-none">
                </div>
                <div class="space-y-2">
                    <label class="font-bold text-gray-700">문의내용</label>
                    <textarea rows="5" placeholder="궁금하신 내용을 입력해주세요" class="w-full bg-gray-50 border-none p-4 rounded-xl focus:ring-2 focus:ring-[#f82a93] outline-none"></textarea>
                </div>
                <button type="submit" class="w-full pink-bg text-white py-5 rounded-xl font-black text-xl hover:opacity-90 transition transform active:scale-95">
                    가맹 문의 신청하기
                </button>
            </form>
        </div>
    </div>

    <script>
        // 커피 메뉴 데이터
        const coffeeMenu = [
            { name: "시그니처 아메리카노", price: "2,500원", label: "Best" },
            { name: "리얼 바닐라라떼", price: "3,800원", label: "Hit" },
            { name: "카페라떼", price: "3,300원", label: "" },
            { name: "헤이즐넛 라떼", price: "3,800원", label: "" },
            { name: "달콤 돌체라떼", price: "4,000원", label: "New" },
            { name: "카라멜 마끼아또", price: "4,000원", label: "" },
            { name: "카페모카", price: "4,000원", label: "" },
            { name: "화이트초코 모카", price: "4,300원", label: "" },
            { name: "연유 콜드브루", price: "4,500원", label: "Cold" },
            { name: "민트초코 라떼", price: "4,300원", label: "" }
        ];

        // 메뉴 목록 렌더링
        const menuListContainer = document.getElementById('menu-list');
        coffeeMenu.forEach(item => {
            const div = document.createElement('div');
            div.className = 'menu-item';
            div.innerHTML = `
                <div class="w-full aspect-square bg-gray-50 rounded-2xl mb-5 flex items-center justify-center text-gray-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="6" y1="2" y2="4"/><line x1="10" x2="10" y1="2" y2="4"/><line x1="14" x2="14" y1="2" y2="4"/></svg>
                </div>
                <div class="min-h-[24px]">
                    ${item.label ? `<span class="text-[10px] pink-bg text-white px-2 py-0.5 rounded-full font-bold uppercase">${item.label}</span>` : ''}
                </div>
                <h4 class="text-lg font-bold mt-2 text-gray-800">${item.name}</h4>
                <p class="pink-point font-bold text-sm mt-1">${item.price}</p>
            `;
            menuListContainer.appendChild(div);
        });

        // 서브 페이지 제어 로직
        function showSubPage(id) {
            document.getElementById(id).classList.add('active');
            document.getElementById('btn-close').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function hideAllSubPages() {
            document.querySelectorAll('.sub-page').forEach(page => {
                page.classList.remove('active');
            });
            document.getElementById('btn-close').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }
    </script>
</body>
</html>
