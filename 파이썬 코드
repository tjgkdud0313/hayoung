import asyncio
from playwright.async_api import async_playwright
import json
import os
import requests
from datetime import datetime, timedelta

# 로그 기록
with open("log.txt", "a", encoding="utf-8") as f:
    f.write("스크립트 시작됨\n")

USER_DATA_DIR = "user_data"
HASHTAGS = ["팝업", "콜라보", "마케팅"]
PER_HASHTAG_LIMIT = 4
WEBHOOK_URL = "http://13.60.96.174:5678/webhook/instagram-to-telegram"

async def manual_login_if_needed(context):
    page = context.pages[0] if context.pages else await context.new_page()
    await page.goto("https://www.instagram.com/", timeout=60000)

    try:
        await page.wait_for_selector('nav', timeout=10000)
        print("로그인 세션 확인됨. 바로 스크래핑을 시작합니다.")
        return page
    except:
        print("세션 없음 또는 만료. 브라우저에서 로그인해주세요.")
        print("로그인 완료 후, 이 터미널에 엔터 키를 눌러주세요.")
        loop = asyncio.get_event_loop()
        await loop.run_in_executor(None, input, "로그인 완료했으면 엔터 → ")
        print("로그인 확인 완료. 스크래핑을 시작합니다.")
        return page

async def scrape_instagram(page):
    results = []
    for hashtag in HASHTAGS:
        tag_url = f"https://www.instagram.com/explore/tags/{hashtag}/"
        print(f"해시태그: {hashtag} → {tag_url}")
        results_per_tag = []
        seen = set()

        try:
            await page.goto(tag_url)
            await page.wait_for_timeout(50000)
            for _ in range(4):
                await page.mouse.wheel(0, 3000)
                await page.wait_for_timeout(2000)
        except Exception as e:
            print(f"페이지 이동 중 오류 발생: {e}")
            continue

        posts = await page.query_selector_all('a[href^="/p/"]')
        print(f"{hashtag} 해시태그에서 수집된 게시물 수: {len(posts)}개")

        for post in posts:
            if len(results_per_tag) >= PER_HASHTAG_LIMIT:
                break

            try:
                href = await post.get_attribute("href")
                if href and href not in seen:
                    seen.add(href)
                    post_url = f"https://www.instagram.com{href}"

                    detail_page = await page.context.new_page()
                    try:
                        await detail_page.goto(post_url, timeout=10000)
                    except Exception as e:
                        print(f"게시물 이동 실패 (skip): {post_url} | 사유: {e}")
                        await detail_page.close()
                        continue

                    img_url, like_count, content_text = None, 0, ""

                    try:
                        img_elems = await detail_page.query_selector_all('img.x5yr21d')
                        print("프로필 이미지 전부 출력해본당" + img_elems)
                        for img_elem in img_elems:
                            try:
                                alt = await img_elem.get_attribute('alt') or ""
                               
                                if "프로필" in alt or "profile" in alt.lower():
                                    print(f"프로필 이미지 스킵 (alt: {alt})")
                                    continue

                                else:
                                    img_url = await img_elem.get_attribute('src') 
                                    print(f"게시물 이미지 제대로 잘 추출됨")
                                    break  # 이미지 찾았으니 반복 종료

                            except Exception as e:
                                print(f"이미지 필터링 중 오류: {e}")
                                continue

                        if not img_url:
                            img_elem = await detail_page.query_selector('video')
                            if img_elem:
                                img_url = await img_elem.get_attribute('poster') or await img_elem.get_attribute('src')
                                print("3번 이걸로 뽑힌당")


                        # 좋아요 수 추출 (댓글 좋아요 제외)
                        last_like_text = ""
                        like_spans = await detail_page.query_selector_all('span')

                        for span in like_spans:
                            try:
                                like_text = (await span.inner_text()).strip()
                               # print(f"span 텍스트: {like_text}")

                                if "좋아요" in like_text and "개" in like_text:
                                    last_like_text = like_text  
                            except:
                                continue

                        if last_like_text:
                            print(f"선택된 좋아요 텍스트: {last_like_text}")
                            clean_text = last_like_text.replace("좋아요", "").replace("개", "").replace(",", "").strip()
                            if "만" in clean_text:
                                try:
                                    like_count = int(float(clean_text.replace("만", "")) * 10000)
                                except:
                                    like_count = 0
                            elif clean_text.isdigit():
                                like_count = int(clean_text)


                        is_recent_post = False

                        try:
                            time_elem = await detail_page.query_selector('time')
                            if time_elem:
                                datetime_str = await time_elem.get_attribute('datetime')  # 예: "2025-07-02T08:21:17.000Z"
                                if datetime_str:
                                    post_datetime = datetime.strptime(datetime_str[:10], "%Y-%m-%d")  # 날짜만 추출
                                    today = datetime.timezone.utcnow().date()
                                    yesterday = today - timedelta(days=7)

                                    if post_datetime.date() in [today, yesterday]:
                                        is_recent_post = True
                                        print(f"게시일: {post_datetime.date()} → 최근 게시물")
                                    else:
                                        print(f"게시일: {post_datetime.date()} → 오래된 게시물")

                        except Exception as e:
                            print(f"날짜 파싱 실패: {e}")
    

                        # 본문 텍스트 추출
                        content_spans = await detail_page.query_selector_all('span._ap3a._aaco._aacu._aacx._aad7._aade')
                        if len(content_spans) >= 2:
                            content_text = await content_spans[1].inner_text()

                    except Exception as e:
                        print(f"정보 파싱 중 예외 발생: {e}")

                    if img_url and (like_count >= 100):
                        print(f"{hashtag} - 좋아요 {like_count} | 이미지 : {img_url} | 링크:{post_url}")
                        result = {
                            "hashtag": hashtag,
                            "post_url": post_url,
                            "image_url": img_url,
                            "likes": like_count,
                            "content": content_text
                        }
                        results_per_tag.append(result)
                    else:
                        print(f"조건 미달 : {post_url} | 좋아요: {like_count} | 이미지 : {img_url}")

                    await detail_page.close()

            except Exception as e:
                print(f"게시물 수집 중 오류 발생: {e}")

        results.extend(results_per_tag)

    if not results:
        print("조건을 만족하는 게시물이 없습니다.")
    else:
        print(json.dumps(results, indent=2, ensure_ascii=False))
        try:
            response = requests.post(WEBHOOK_URL, json=results)
            print(f"전체 웹훅 전송 상태: {response.status_code}")
        except Exception as e:
            print(f"전체 웹훅 전송 실패: {e}")

async def main():
    async with async_playwright() as p:
        context = await p.chromium.launch_persistent_context(
            user_data_dir=USER_DATA_DIR,
            headless=False,
            timeout=60000
        )

        page = await manual_login_if_needed(context)
        await scrape_instagram(page)
        await context.close()

if __name__ == "__main__":
    asyncio.run(main())
